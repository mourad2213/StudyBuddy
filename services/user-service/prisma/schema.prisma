generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL") 
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  university String?
  year       Int?
  createdAt  DateTime @default(now())
}